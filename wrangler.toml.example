# Template for your Atlas deployment.
#
# This repo does NOT ship a tracked wrangler.toml — each contributor/user
# customizes their own (name, R2 bucket, account_id) and that copy stays
# gitignored. Either run the `/atlas-onboarding` skill, or:
#
#   cp wrangler.toml.example wrangler.toml
#   # then edit `name`, `bucket_name`, and (if you have >1 CF account) add
#   # `account_id = "<your-cf-account-id>"`
#   npx wrangler r2 bucket create <your-bucket-name>
#   npx wrangler secret put STEEL_API_KEY
#   npx wrangler secret put ANTHROPIC_API_KEY
#   npx wrangler secret put ATLAS_API_KEY
#   npx wrangler deploy

name = "atlas"
main = "src/index.ts"
compatibility_date = "2025-01-22"
compatibility_flags = ["nodejs_compat"]
# Durable Object — one instance per async job (job_id keyed via idFromName)
[[durable_objects.bindings]]
name = "ATLAS_JOB"
class_name = "AtlasJob"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["AtlasJob"]

[[r2_buckets]]
binding = "ARTIFACTS"
bucket_name = "atlas-artifacts"

# --- Secrets (set via `wrangler secret put <NAME>`) ---
#   ATLAS_API_KEY          Required. Shared bearer token clients send as
#                          `Authorization: Bearer …`. Validated timing-safe.
#   STEEL_API_KEY          Required. Outbound Steel calls.
#   ANTHROPIC_API_KEY      Required. LLM work (Haiku + Sonnet).
#
# --- Optional vars ---
#   STEEL_BASE_URL         Override Steel endpoint (self-hosted Steel).

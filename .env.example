# Required — Steel Browser (https://app.steel.dev)
STEEL_API_KEY=

# Model provider — set one. Defaults to anthropic unless only OPENAI_API_KEY is set.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# DRACO eval judge (optional) — default judge is gemini-3.1-pro-preview, the current
# successor to the paper's retired gemini-3-pro-preview. Falls back to
# --judge-provider anthropic|openai if unset.
# GOOGLE_GENERATIVE_AI_API_KEY=

# Provider / model selection (optional)
# ATLAS_PROVIDER=anthropic
# ATLAS_MODEL=

# Search backend keys (optional) — needed for --search-provider exa|brave
# EXA_API_KEY=
# BRAVE_API_KEY=

# Run tuning (optional)
# ATLAS_TOKEN_LIMIT=2000000
# ATLAS_REANCHOR_TOKENS=150000        # lead re-anchor threshold; raise for large-context models
# ATLAS_BROWSER_IDLE_TTL_MS=120000

# Self-hosted Steel (optional)
# STEEL_BASE_URL=

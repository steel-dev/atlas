# Required — Steel Browser (https://app.steel.dev)
STEEL_API_KEY=

# Model provider — set one. Defaults to anthropic unless only OPENAI_API_KEY is set.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# DRACO eval judge (optional) — replicates the paper's Gemini-3-Pro judge.
# Falls back to --judge-provider anthropic|openai if unset.
# GOOGLE_GENERATIVE_AI_API_KEY=

# Provider / model selection (optional)
# ATLAS_PROVIDER=anthropic
# ATLAS_MODEL=
# ATLAS_SUMMARY_MODEL=
# OPENAI_BASE_URL=

# Search backend keys (optional) — needed for --search-provider exa|brave
# EXA_API_KEY=
# BRAVE_API_KEY=

# Run tuning (optional)
# ATLAS_TOKEN_LIMIT=2000000
# ATLAS_TEAM_SIZE=1
# ATLAS_MAX_SUBAGENTS=
# ATLAS_MAX_DELEGATION_DEPTH=1
# ATLAS_COMPACTION_TRIGGER_TOKENS=200000
# ATLAS_BROWSER_IDLE_TTL_MS=120000

# Self-hosted Steel (optional)
# STEEL_BASE_URL=

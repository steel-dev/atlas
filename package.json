{
  "name": "@steel-dev/atlas",
  "version": "0.1.0",
  "description": "Deep research from your terminal or your code. Backed by Steel Browser and model providers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    }
  },
  "bin": {
    "atlas": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "eval:browsecomp": "tsx evals/browsecomp.ts",
    "eval:browsecomp:official": "tsx evals/browsecomp.ts --cases https://openaipublic.blob.core.windows.net/simple-evals/browse_comp_test_set.csv",
    "eval:draco": "tsx evals/draco.ts",
    "eval:draco:explore": "tsx evals/explore/cli.ts",
    "draco:q": "tsx evals/explore/query.ts",
    "eval:typecheck": "tsc -p evals/tsconfig.json && tsc -p evals/explore/tsconfig.client.json",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp src/serve.page.html dist/serve.page.html && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.67",
    "cheerio": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "steel-sdk": "^0.18.0",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.194",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "deep-research",
    "research",
    "cli",
    "anthropic",
    "claude",
    "openai",
    "steel",
    "web-search",
    "agent",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steel-experiments/atlas.git"
  }
}
